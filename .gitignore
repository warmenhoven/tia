*.o
*.d
*.a
*.so
*.dll
*.dylib
*.bc
*.lib
*.exp
*.ilk
*.pdb
*.dSYM/

# Unit-test binaries (extension-less); keep their sources.
tests/unit/test_*
!tests/unit/test_*.c
!tests/unit/test_*.h

# Oracle-harness tool binary (extension-less); source is checked in.
tests/tools/run_tia_c
!tests/tools/run_tia_c.c

# Native Sim2600 port (tests/oracle/csim): sources + Makefile + converter
# + verifier are checked in.  Everything below is produced by `make`,
# `convert.py`, or by running the binary, and is regenerated on demand.
tests/oracle/csim/sim2600
tests/oracle/csim/*.ndjson
tests/oracle/csim/*.trace
tests/oracle/csim/*.pix
tests/oracle/csim/*.vtrace
tests/oracle/csim/*.csv
tests/oracle/csim/*.log

# Python
tests/int/.venv/
__pycache__/
*.pyc

# Build artifacts
tia_libretro*

# Test data fetched on demand by tests/tools/fetch_harte.py
tests/unit/roms/harte_65x02.bin

# Oracle test harness — Sim2600 is supplied externally (either as a git
# submodule or a dev-setup clone, TBD). Golden traces are generated from
# it and re-generation is a manual step, so we don't check them in either.
tests/oracle/Sim2600/
tests/oracle/golden/

# Test ROMs are generated on demand by tests/tools/build_test_roms.py;
# the generator is source of truth.
tests/oracle/test_roms/

# Editors
.DS_Store
*.swp
*~
